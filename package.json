{
  "name": "eslint-config-devjskit",
  "version": "2.0.0",
  "description": "ESLint and Prettier configuration from devjskit",
  "main": "index.js",
  "prettier": "prettier-config-devjskit",
  "author": "Billgo <hi@billgo.me>",
  "license": "MIT",
  "keywords": [
    "eslint",
    "eslintconfig",
    "config",
